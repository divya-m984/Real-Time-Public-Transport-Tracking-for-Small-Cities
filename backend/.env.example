PORT=3000

# ── Road routing ──────────────────────────────────────────────────────────────
# Routing provider used to generate road-following route geometry.
# Currently only 'osrm' is supported.
ROAD_ROUTING_PROVIDER=osrm

# Base URL for the OSRM route service.
# Default: public OSRM demo server (rate-limited; suitable for development only).
# For production, run a self-hosted OSRM instance:
#   https://github.com/Project-OSRM/osrm-backend
# Do NOT commit a private or paid routing API key/URL.
OSRM_BASE_URL=https://router.project-osrm.org

# Request timeout in milliseconds (default: 8000).
# Journey search returns a fallback geometry if OSRM does not respond in time.
OSRM_TIMEOUT_MS=8000
